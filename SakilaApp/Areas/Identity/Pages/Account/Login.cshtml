@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h2>Welcome Back</h2>
        <p class="text-muted">Use a local account to log in.</p>
        
        <section>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="checkbox">
                        <label asp-for="Input.RememberMe" class="form-label mb-0">
                            <input class="form-check-input me-2" asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="small">Forgot password?</a>
                </div>
                
                <div class="mb-3">
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
                
                <div class="text-center mt-4">
                    <p class="mb-1 text-muted">Don't have an account?</p>
                    <p class="mb-1">
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                    </p>
                    <p class="small mt-3">
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-muted">Resend email confirmation</a>
                    </p>
                </div>
            </form>
        </section>

        @{
            if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <hr />
                <section class="text-center">
                    <p class="text-muted small mb-3">Or continue with</p>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div>
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-secondary w-100 mb-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                    @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                </section>
            }
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
